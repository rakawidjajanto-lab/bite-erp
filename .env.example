# ─────────────────────────────────────────────────────────────────────────────
# BITE ERP — Environment Variables
# Copy this file to .env.local for local development.
# Add each variable in: Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Database (Supabase PostgreSQL — use the connection POOLER URL for serverless/Vercel)
# Found in: Supabase Dashboard → Project Settings → Database → Connection string → URI (Mode: Transaction)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-[region].pooler.supabase.com:5432/postgres"

# Supabase Auth (public — safe to expose in browser)
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Cron job secret — used to protect /api/cron/* endpoints
# Generate any random string, e.g.: openssl rand -hex 32
# Add this same value in Vercel Dashboard → Project → Settings → Cron Jobs → Authorization header
CRON_SECRET="replace-with-a-random-secret-string"
