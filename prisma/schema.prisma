generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TransactionCategory {
  INVESTMENT
  SALES
  SUPPLIES
  OPERATIONAL
  MARKETING
  RND
  INVENTORY
  OTHER_INCOME
}

enum TransactionSource {
  MANUAL
  TOKOPEDIA
  SHOPEE
  PADEL
  EXCEL_IMPORT
  ORDER
}

enum InvestmentDirection {
  IN
  OUT
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum MarketingPurpose {
  ENDORSEMENT
  SAMPLING
  EVENT
  OTHER
}

enum MovementType {
  RESTOCK
  SALE
  WASTE
  ADJUSTMENT
  PADEL_DELIVERY
  RND_USAGE
  MARKETING_GIVEAWAY
}

enum RndStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssetCategory {
  MACHINE
  FREEZER
  FURNITURE
  VEHICLE
  ELECTRONICS
  OTHER
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum ImportSource {
  EXCEL
  TOKOPEDIA_CSV
  SHOPEE_CSV
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Transaction {
  id                  String              @id @default(cuid())
  date                DateTime            @db.Date
  description         String
  category            TransactionCategory
  amountIn            Decimal?            @db.Decimal(15, 2)
  amountOut           Decimal?            @db.Decimal(15, 2)
  source              TransactionSource   @default(MANUAL)
  investmentDirection InvestmentDirection?
  investorName        String?
  subCategory         String?
  referenceId         String?
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  platformOrder  PlatformOrder?
  rndExpenses    RndExpense[]
  supplyPurchases SupplyPurchase[]
  customerOrder  CustomerOrder?
  inventoryLinks InventoryTransactionLink[]

  @@map("transactions")
}

model Platform {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  orders PlatformOrder[]

  @@map("platforms")
}

model PlatformOrder {
  id              String      @id @default(cuid())
  platformId      String
  externalOrderId String
  orderDate       DateTime    @db.Date
  status          OrderStatus @default(PENDING)
  grossAmount     Decimal     @db.Decimal(15, 2)
  platformFee     Decimal     @default(0) @db.Decimal(15, 2)
  shippingCost    Decimal     @default(0) @db.Decimal(15, 2)
  discount        Decimal     @default(0) @db.Decimal(15, 2)
  netAmount       Decimal     @db.Decimal(15, 2)
  customerName    String?
  settlementDate  DateTime?   @db.Date  @map("settlement_date")
  transactionId   String?     @unique
  rawData         Json?
  createdAt       DateTime    @default(now())

  platform    Platform        @relation(fields: [platformId], references: [id])
  transaction Transaction?    @relation(fields: [transactionId], references: [id])
  items       PlatformOrderItem[]

  @@unique([platformId, externalOrderId])
  @@map("platform_orders")
}

model PlatformOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  flavorId    String?
  productName String?  @map("product_name")
  quantity    Int
  unitPrice   Decimal  @db.Decimal(15, 2)
  subtotal    Decimal  @db.Decimal(15, 2)

  order   PlatformOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?      @relation(fields: [productId], references: [id])
  flavor  Flavor?       @relation(fields: [flavorId], references: [id])

  @@map("platform_order_items")
}

model Product {
  id           String  @id @default(cuid())
  name         String
  sku          String  @unique
  unitCost     Decimal @db.Decimal(15, 2)
  sellingPrice Decimal @db.Decimal(15, 2)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())

  flavors            Flavor[]
  inventory          Inventory[]
  inventoryMovements InventoryMovement[]
  orderItems         PlatformOrderItem[]
  giveawayItems      MarketingGiveawayItem[]
  rndUsages          RndInventoryUsage[]
  variants           ProductVariant[]

  @@map("products")
}

model Flavor {
  id        String  @id @default(cuid())
  name      String
  productId String
  isActive  Boolean @default(true)
  colorHex  String?
  createdAt DateTime @default(now())

  product            Product                 @relation(fields: [productId], references: [id])
  inventory          Inventory[]
  inventoryMovements InventoryMovement[]
  orderItems         PlatformOrderItem[]
  deliveryItems      PadelDeliveryItem[]
  padelSales         PadelSale[]
  rndProjects        RndProject[]
  giveawayItems      MarketingGiveawayItem[]
  rndUsages          RndInventoryUsage[]
  variants           ProductVariant[]

  @@map("flavors")
}

model Inventory {
  id           String   @id @default(cuid())
  productId    String
  flavorId     String?
  quantity     Int      @default(0)
  unit         String   @default("pcs")
  reorderPoint Int      @default(0)
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  flavor  Flavor? @relation(fields: [flavorId], references: [id])

  @@unique([productId, flavorId])
  @@map("inventory")
}

model InventoryMovement {
  id            String       @id @default(cuid())
  productId     String
  flavorId      String?
  movementType  MovementType
  quantityChange Int
  referenceId   String?
  notes         String?
  createdAt     DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
  flavor  Flavor? @relation(fields: [flavorId], references: [id])

  @@map("inventory_movements")
}

model PadelVenue {
  id           String  @id @default(cuid())
  name         String
  contactName  String?
  contactPhone String?
  location     String?
  isActive     Boolean @default(true)

  deliveries PadelDelivery[]
  sales      PadelSale[]

  @@map("padel_venues")
}

model PadelDelivery {
  id           String   @id @default(cuid())
  venueId      String
  deliveryDate DateTime @db.Date
  notes        String?
  totalItems   Int      @default(0)
  createdAt    DateTime @default(now())

  venue PadelVenue         @relation(fields: [venueId], references: [id])
  items PadelDeliveryItem[]

  @@map("padel_deliveries")
}

model PadelDeliveryItem {
  id         String  @id @default(cuid())
  deliveryId String
  flavorId   String
  quantity   Int
  unitCost   Decimal @db.Decimal(15, 2)

  delivery PadelDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  flavor   Flavor        @relation(fields: [flavorId], references: [id])

  @@map("padel_delivery_items")
}

model PadelSale {
  id          String   @id @default(cuid())
  venueId     String
  saleDate    DateTime @db.Date
  flavorId    String
  quantitySold Int
  unitPrice   Decimal  @db.Decimal(15, 2)
  totalAmount Decimal  @db.Decimal(15, 2)
  notes       String?
  createdAt   DateTime @default(now())

  venue  PadelVenue @relation(fields: [venueId], references: [id])
  flavor Flavor     @relation(fields: [flavorId], references: [id])

  @@map("padel_sales")
}

model RndProject {
  id              String    @id @default(cuid())
  name            String
  description     String?
  status          RndStatus @default(PLANNING)
  startDate       DateTime  @db.Date
  endDate         DateTime? @db.Date
  targetFlavorId  String?
  createdAt       DateTime  @default(now())

  targetFlavor Flavor?       @relation(fields: [targetFlavorId], references: [id])
  expenses     RndExpense[]
  materials    RndMaterial[]

  @@map("rnd_projects")
}

model RndExpense {
  id            String   @id @default(cuid())
  projectId     String
  transactionId String?
  date          DateTime @db.Date
  description   String
  amount        Decimal  @db.Decimal(15, 2)
  subCategory   String?

  project         RndProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  transaction     Transaction?        @relation(fields: [transactionId], references: [id])
  inventoryUsages RndInventoryUsage[]

  @@map("rnd_expenses")
}

model Supply {
  id           String  @id @default(cuid())
  name         String
  supplierName String?
  unit         String
  unitCost     Decimal @db.Decimal(15, 2)
  currentStock Decimal @default(0) @db.Decimal(10, 2)
  reorderPoint Decimal @default(0) @db.Decimal(10, 2)
  notes        String?

  purchases SupplyPurchase[]

  @@map("supplies")
}

model SupplyPurchase {
  id              String   @id @default(cuid())
  supplyId        String
  transactionId   String?
  purchaseDate    DateTime @db.Date
  quantity        Decimal  @db.Decimal(10, 2)
  unitCost        Decimal  @db.Decimal(15, 2)
  totalCost       Decimal  @db.Decimal(15, 2)
  supplierInvoice String?

  supply      Supply       @relation(fields: [supplyId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@map("supply_purchases")
}

model FinancialProjection {
  id                String   @id @default(cuid())
  projectionMonth   DateTime @db.Date
  projectedRevenue  Decimal  @db.Decimal(15, 2)
  projectedExpenses Decimal  @db.Decimal(15, 2)
  projectedProfit   Decimal  @db.Decimal(15, 2)
  actualRevenue     Decimal? @db.Decimal(15, 2)
  actualExpenses    Decimal? @db.Decimal(15, 2)
  actualProfit      Decimal? @db.Decimal(15, 2)
  method            String   @default("moving_average")
  confidenceScore   Decimal? @db.Decimal(5, 2)
  notes             String?
  createdAt         DateTime @default(now())

  @@unique([projectionMonth])
  @@map("financial_projections")
}

model ImportLog {
  id          String       @id @default(cuid())
  fileName    String
  source      ImportSource
  status      ImportStatus @default(PENDING)
  rowsTotal   Int          @default(0)
  rowsImported Int         @default(0)
  rowsFailed  Int          @default(0)
  errorLog    Json?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@map("import_logs")
}

model MarketingGiveaway {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  recipient String
  purpose   MarketingPurpose
  notes     String?
  createdAt DateTime         @default(now())

  items MarketingGiveawayItem[]

  @@map("marketing_giveaways")
}

model MarketingGiveawayItem {
  id         String  @id @default(cuid())
  giveawayId String
  productId  String
  flavorId   String?
  quantity   Int
  unitCost   Decimal @db.Decimal(15, 2)

  giveaway MarketingGiveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id])
  flavor   Flavor?           @relation(fields: [flavorId], references: [id])

  @@map("marketing_giveaway_items")
}

model PhysicalAsset {
  id            String        @id @default(cuid())
  name          String
  category      AssetCategory
  purchaseDate  DateTime      @db.Date
  purchasePrice Decimal       @db.Decimal(15, 2)
  currentValue  Decimal       @db.Decimal(15, 2)
  notes         String?
  createdAt     DateTime      @default(now())

  @@map("physical_assets")
}

model RndInventoryUsage {
  id        String  @id @default(cuid())
  expenseId String
  productId String
  flavorId  String?
  quantity  Int
  unitCost  Decimal @db.Decimal(15, 2)

  expense RndExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])
  flavor  Flavor?    @relation(fields: [flavorId], references: [id])

  @@map("rnd_inventory_usages")
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  flavorId     String?
  size         String
  sellingPrice Decimal  @db.Decimal(15, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  product     Product                   @relation(fields: [productId], references: [id])
  flavor      Flavor?                   @relation(fields: [flavorId], references: [id])
  ingredients ProductVariantIngredient[]
  orderItems  CustomerOrderItem[]

  @@map("product_variants")
}

model ProductVariantIngredient {
  id           String  @id @default(cuid())
  variantId    String
  name         String
  quantity     Decimal @db.Decimal(10, 4)
  unit         String
  pricePerUnit Decimal @db.Decimal(15, 2)

  variant      ProductVariant           @relation(fields: [variantId], references: [id], onDelete: Cascade)
  priceHistory IngredientPriceHistory[]

  @@map("product_variant_ingredients")
}

model IngredientPriceHistory {
  id             String   @id @default(cuid())
  ingredientId   String
  ingredientName String
  variantId      String
  oldPrice       Decimal  @db.Decimal(15, 2)
  newPrice       Decimal  @db.Decimal(15, 2)
  changedAt      DateTime @default(now())

  ingredient ProductVariantIngredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@map("ingredient_price_history")
}

model SupplyItem {
  id             String   @id @default(cuid())
  name           String
  unit           String
  gramsPerUnit   Decimal  @default(1) @db.Decimal(10, 4)
  stock          Decimal  @default(0) @db.Decimal(10, 4)
  stockVenue     Decimal  @default(0) @db.Decimal(10, 4)
  stockEcommerce Decimal  @default(0) @db.Decimal(10, 4)
  pricePerUnit   Decimal  @default(0) @db.Decimal(15, 2)
  createdAt      DateTime @default(now())

  rndMaterials   RndMaterial[]
  inventoryLinks InventoryTransactionLink[]

  @@map("supply_items")
}

model RndMaterial {
  id            String   @id @default(cuid())
  projectId     String
  supplyItemId  String
  quantityUsed  Decimal  @db.Decimal(10, 4)
  valuationCost Decimal  @db.Decimal(15, 2)
  createdAt     DateTime @default(now())

  project    RndProject @relation(fields: [projectId],    references: [id], onDelete: Cascade)
  supplyItem SupplyItem @relation(fields: [supplyItemId], references: [id])

  @@map("rnd_materials")
}

model InventoryTransactionLink {
  id            String   @id @default(cuid())
  supplyItemId  String
  transactionId String   @unique
  quantityAdded Decimal  @db.Decimal(10, 4)
  location      String   @default("VENUE")
  createdAt     DateTime @default(now())

  supplyItem  SupplyItem  @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("inventory_transaction_links")
}

model CustomerOrder {
  id            String   @id @default(cuid())
  orderDate     DateTime @db.Date
  customerName  String
  subtotal      Decimal      @db.Decimal(15, 2)
  deliveryFee   Decimal      @default(0) @db.Decimal(15, 2)
  discountType  DiscountType @default(FIXED)
  discountValue Decimal      @default(0) @db.Decimal(15, 2)
  total         Decimal      @db.Decimal(15, 2)
  notes         String?
  transactionId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items       CustomerOrderItem[]
  transaction Transaction?        @relation(fields: [transactionId], references: [id])

  @@map("customer_orders")
}

model CustomerOrderItem {
  id        String  @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(15, 2)
  subtotal  Decimal @db.Decimal(15, 2)

  order   CustomerOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("customer_order_items")
}
